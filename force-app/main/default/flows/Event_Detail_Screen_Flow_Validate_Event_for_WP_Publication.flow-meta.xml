        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Group_Check</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Create Public Group</defaultConnectorLabel>
        <rules>
            <name>Yes_Existing_Group</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Event_Detail.Public_Group__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
