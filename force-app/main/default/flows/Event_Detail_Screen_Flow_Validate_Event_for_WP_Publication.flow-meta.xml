        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>New_Public_Group</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Create</defaultConnectorLabel>
        <rules>
            <name>Yes_Use_Group</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Group_Check.Id</leftValueReference>
