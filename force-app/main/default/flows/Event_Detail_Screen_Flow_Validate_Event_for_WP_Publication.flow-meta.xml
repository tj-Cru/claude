        </rules>
    </decisions>
    <decisions>
        <name>Source</name>
        <label>Source</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Source_Error_Screen</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Cvent</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Event_Detail.Source__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Cvent</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Cvent_Specific_Values</targetReference>
            </connector>
            <label>Cvent</label>
        </rules>
        <rules>
            <name>ERT</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>Event_Detail.Source__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ERT</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Event_Detail.Source__c</leftValueReference>
                <operator>EqualTo</operator>
            </conditions>
            <connector>
                <targetReference>ERT_Specific_Values</targetReference>
            </connector>
            <label>ERT</label>
        </rules>
    </decisions>
    <description>Adds the creation of the public group used later for sharing records with the event team</description>
    <environments>Default</environments>
    <formulas>
        <name>forCventLink</name>
        <dataType>Boolean</dataType>
        <expression>IF(ISNULL({!Event_Detail.Cvent_Site__c}),false,true)</expression>
    </formulas>
    <formulas>
        <name>forERTLinks</name>
        <dataType>Boolean</dataType>
        <expression>IF(
OR(IsNull({!Event_Detail.Registration_Link__c}),
IsNull({!Event_Detail.Registration_Link_Military__c}),
IsNull({!Event_Detail.Registration_Link_Pastor__c})

)
,false,true)</expression>
    </formulas>
    <formulas>
        <name>forERTPricing</name>
        <dataType>Boolean</dataType>
        <expression>
IF(
OR(IsNULL({!Event_Detail.Registration_Price__c}),
IsNull({!Event_Detail.Registration_Price_Military__c}),
IsNull({!Event_Detail.Registration_Price_Pastor__c})
)
,false,true)</expression>
    </formulas>
    <formulas>
        <name>forGeoCode</name>
        <dataType>Boolean</dataType>
        <expression>IF(OR(ISNULL({!Event_Detail.Event_Geo__Latitude__s}),ISNULL({!Event_Detail.Event_Geo__Longitude__s})),false,true)</expression>
    </formulas>
    <formulas>
        <name>forLocation</name>
        <dataType>Boolean</dataType>
        <expression>IF(
OR(
ISNULL({!Event_Detail.Hotel_Location__c}),
ISNULL({!Event_Detail.Conference_Location__c})
)
,false,true)</expression>
    </formulas>
    <formulas>
        <name>forPublished</name>
        <dataType>Boolean</dataType>
        <expression>IF(TEXT({!Event_Detail.Stage__c})=&apos;Planning&apos;,true,false)</expression>
    </formulas>
    <formulas>
        <name>forSpeakerCount</name>
        <dataType>Boolean</dataType>
        <expression>IF({!numSpeakerCount}&gt;1,true,false)</expression>
    </formulas>
    <formulas>
        <name>PubGroupName</name>
        <dataType>String</dataType>
        <expression>&quot;WTR00&quot;&amp; RIGHT({!Event_Detail.EventCode__c},4)</expression>
    </formulas>
